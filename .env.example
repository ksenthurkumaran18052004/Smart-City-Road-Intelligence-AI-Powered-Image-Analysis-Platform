# Smart City AI Platform - Environment Configuration
# Copy this to .env and modify as needed

# Device: cuda or cpu
DEVICE=cuda

# Upload settings
MAX_UPLOAD_SIZE=500000000

# Video processing
FRAME_SAMPLING_INTERVAL=0.5
ACCIDENT_THRESHOLD=0.7

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Tesseract path (leave empty if in PATH)
TESSERACT_PATH=
